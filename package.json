{
  "name": "next.js-mcp-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "preview": "next build && next start",
    "dev": "next dev",
    "start": "next start",
    "check": "ultracite check",
    "check:unsafe": "ultracite fix --unsafe",
    "check:write": "ultracite fix .",
