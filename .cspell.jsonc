{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "dictionaries": ["software-terms", "npm"],
  "files": ["**", ".github/**", ".claude/**"],
  "ignorePaths": ["bun.lock", "bun.lockb"],
  "import": ["@cspell/dict-bash/cspell-ext.json"],
  "useGitignore": true,
  "version": "0.2",
  "words": [
    "ciphertext",
    "fathom",
    "hugeicons",
    "lefthook",
    "luma",
    "modelcontextprotocol",
    "oslojs",
    "pkce",
    "Qwik",
    "sess",
    "streamable",
    "Streamable",
    "techwithanirudh",
    "trycloudflare",
    "uidx",
    "ultracite"
  ]
}
