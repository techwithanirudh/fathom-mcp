{
  "name": "Fathom MCP",
  "build": {
    "dockerfile": "./Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": "true",
      "configureZshAsDefaultShell": "true",
      "installOhMyZsh": "true",
      "installOhMyZshConfig": "true",
      "username": "coder",
      "userUid": "1000",
      "userGid": "1000",
      "upgradePackages": "true"
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "os-provided"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24",
      "nodeGypDependencies": "false"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": "false"
    },
    "ghcr.io/devcontainers-extra/features/bun:1": {
      "version": "latest"
    },
    "ghcr.io/coder/devcontainer-features/code-server:1": {
      "auth": "none",
      "port": 13337
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
    "./local-features/setup-user": {}
  },
  "overrideFeatureInstallOrder": [
    "ghcr.io/devcontainers/features/common-utils",
    "ghcr.io/devcontainers/features/git",
    "ghcr.io/devcontainers/features/node",
    "ghcr.io/devcontainers-extra/features/bun",
    "ghcr.io/devcontainers/features/github-cli",
    "ghcr.io/devcontainers/features/docker-in-docker",
    "ghcr.io/anthropics/devcontainer-features/claude-code",
    "ghcr.io/coder/devcontainer-features/code-server",
    "./local-features/setup-user"
  ],
  "remoteUser": "coder",
  "containerUser": "coder",
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "BUN_INSTALL": "${localEnv:BUN_INSTALL}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "VERCEL_TOKEN": "${localEnv:VERCEL_TOKEN}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "better-ts-errors.better-ts-errors",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "oven.bun-vscode",
        "redhat.vscode-yaml",
        "streetsidesoftware.code-spell-checker",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "debug.internalConsoleOptions": "neverOpen",
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true,
        "editor.guides.bracketPairs": "active",
        "scm.defaultViewMode": "tree",
        "diffEditor.diffAlgorithm": "advanced",
        "diffEditor.experimental.showMoves": true,
        "diffEditor.renderSideBySide": false,
        "files.watcherExclude": {
          "**/node_modules/**": true
        },
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  },
  "mounts": [
    "source=coder-coder-devcontainer-home,target=/home/coder,type=volume",
    "source=${localEnv:HOME},target=/mnt/home/coder,type=bind,readonly"
  ],
  "postStartCommand": {
    "docker": "sudo service docker start"
  },
  "postCreateCommand": [
    "./.devcontainer/scripts/post-create.sh"
  ]
}
